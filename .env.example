# ============================================================
# SENTINEL — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git.
# ============================================================

# --- HuggingFace ---
# Get from: https://huggingface.co/settings/tokens
# Required for: Llama-3-8B Inference API (agent action generation)
HF_TOKEN=hf_your_token_here

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
# Required for: Oracle agent scenario generation (GPT-4o-mini)
OPENAI_API_KEY=sk-your_key_here

# --- Optional overrides ---
# HF model for agent inference (default: meta-llama/Meta-Llama-3-8B-Instruct)
# HF_INFERENCE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# OpenAI model for Oracle (default: gpt-4o-mini — cheapest capable model)
# OPENAI_MODEL=gpt-4o-mini

# Set to "true" to force heuristic mode even when API keys are present (for tests/CI)
# SENTINEL_HEURISTIC_MODE=false
